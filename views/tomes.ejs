<html>
  <head>
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include("./partials/navbar", {links}) %> <%-
    include("./partials/addTome") %>
    <h1><%= title %></h1>
    <ul>
      <% tomes.forEach((item) => { %>
      <li>
        id: <%= item.shop_inventory_id %>; name: <%= item.name %>; spell type:
        <%= item.type %>; spell school: <%= item.spell_school_id %>; mana cost:
        <%= item.mana_cost %>;
        <a href="/<%= item.id %>/update">Update</a>
        <form action="/<%= item.id %>/delete" method="POST">
          <button
            type="submit"
            onclick="return confirm('Are you sure this item no longer belongs?');"
          >
            Delete
          </button>
        </form>
      </li>
      <% }) %>
    </ul>
  </body>
</html>
