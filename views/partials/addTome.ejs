<form action="/tomes" method="POST">
  <label for="name">Name: </label>
  <input type="text" name="name" id="name" required />
  <label for="spell_type_id">Spell Type: </label>
  <select name="spell_type_id" id="spell_type_id">
    <option value="1">Destruction</option>
    <option value="2">Blessing</option>
    <option value="3">Curse</option>
    <option value="4">Illusion</option>
  </select>
  <label for="spell_school_id">Spell School: </label>
  <select name="spell_school_id" id="spell_school_id">
    <option value="1">Vahseel</option>
    <option value="2">Nuhlkesh</option>
    <option value="3">Xiaovet</option>
  </select>
  <label for="mana_cost">Mana Cost: </label>
  <input
    type="range"
    name="mana_cost"
    id="mana_cost"
    min="1"
    max="100"
    value="1"
  />
  <label for="weight">Weight: </label>
  <input type="range" name="weight" id="weight" min="1" max="100" value="1" />
  <label for="value">Value: </label>
  <input type="number" name="value" id="value" min="1" max="1000" value="1" />
  <button type="submit">Submit</button>
</form>
