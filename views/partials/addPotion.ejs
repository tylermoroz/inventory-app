<form action="/potions" method="POST">
  <label for="name">Name: </label>
  <input type="text" name="name" id="name" required />
  <label for="potion-type">Potion Type: </label>
  <select name="potion-type" id="potion-type">
    <option value="cleanse">Cleanse</option>
    <option value="poison">Poison</option>
    <option value="fortify">Fortify</option>
    <option value="weaken">Weaken</option>
    <option value="healing">Healing</option>
  </select>
  <label for="duration">Duration: </label>
  <input
    type="range"
    name="duration"
    id="duration"
    min="1"
    max="20"
    value="1"
  />
  <label for="weight">Weight: </label>
  <input type="range" name="weight" id="weight" min="1" max="100" value="1" />
  <label for="value">Value: </label>
  <input type="number" name="value" id="value" min="1" max="1000" value="1" />
  <button type="submit">Submit</button>
</form>
