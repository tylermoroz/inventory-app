<form action="/potions" method="POST">
  <label for="name">Name: </label>
  <input type="text" name="name" id="name" required />
  <label for="potion_type_id">Potion Type: </label>
  <select name="potion_type_id" id="potion_type_id">
    <option value="1">Cleanse</option>
    <option value="2">Poison</option>
    <option value="3">Fortify</option>
    <option value="4">Weaken</option>
    <option value="5">Healing</option>
  </select>
  <label for="duration">Duration: </label>
  <input
    type="range"
    name="duration"
    id="duration"
    min="1"
    max="20"
    value="1"
  />
  <label for="weight">Weight: </label>
  <input type="range" name="weight" id="weight" min="1" max="100" value="1" />
  <label for="value">Value: </label>
  <input type="number" name="value" id="value" min="1" max="1000" value="1" />
  <button type="submit">Submit</button>
</form>
